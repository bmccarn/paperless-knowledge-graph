# Paperless-ngx connection.
# If the KG backend runs in Docker and Paperless is published on the host at :8000,
# host.docker.internal works on Docker Desktop. On Linux, use the host LAN IP or
# add a host-gateway override.
PAPERLESS_URL=http://host.docker.internal:8000
PAPERLESS_TOKEN=replace-with-paperless-api-token
PAPERLESS_EXTERNAL_URL=http://localhost:8000
PAPERLESS_SKIP_TAG_NAMES=needs-review

# LLM and embeddings. This app expects an OpenAI-compatible LiteLLM endpoint.
LITELLM_URL=http://host.docker.internal:4000
LITELLM_API_KEY=replace-with-litellm-key
GEMINI_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-large

# Docker-compose service names used by the main docker-compose.yml.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

POSTGRES_HOST=pgvector
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_graph
POSTGRES_USER=kguser
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379

# If you run the backend directly on the host against examples/docker-compose.datastores.yml,
# use these values instead:
# NEO4J_URI=bolt://localhost:7687
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# REDIS_URL=redis://localhost:6379

OWNER_NAME=Your Name
OWNER_CONTEXT=Brief context about yourself for better query answers
MAX_CONCURRENT_DOCS=2
AUTO_SYNC_INTERVAL_MINUTES=0
ENTITY_STEWARD_INTERVAL_MINUTES=360
